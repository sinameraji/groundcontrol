# ── Discord ────────────────────────────────────────────────────────────────
# One bot token per agent. Create one application per agent at
# https://discord.com/developers/applications (enable the MESSAGE CONTENT
# intent under Bot → Privileged Gateway Intents). The env var name for each
# agent's token is declared in config/agents.json (tokenEnv).
DISCORD_TOKEN_SCOUT=
DISCORD_TOKEN_CODEY=

# Your own Discord user id (enable Developer Mode, right-click yourself →
# Copy User ID). Only this user can command the agents.
OWNER_DISCORD_USER_ID=

# The Discord server (guild) id — used to register slash commands instantly.
DISCORD_GUILD_ID=

# ── hotcell daemon ─────────────────────────────────────────────────────────
HOTCELL_ENDPOINT=http://127.0.0.1:4750
HOTCELL_API_KEY=

# ── Artifacts / file links ─────────────────────────────────────────────────
# Where mission folders live. Point this at your big external drive, e.g.
# /Volumes/MyDrive/groundcontrol/missions
ARTIFACTS_ROOT=./data/missions

# Tailnet HTTPS base URL that fronts the built-in file server, e.g.
# https://your-machine.your-tailnet.ts.net
# (set up once with: tailscale serve --bg http://127.0.0.1:4760)
PUBLIC_BASE_URL=
FILES_PORT=4760

# ── Missions ───────────────────────────────────────────────────────────────
MAX_CONCURRENT_MISSIONS=2
OPENROUTER_MODEL=moonshotai/kimi-k2.5
MISSION_SPEND_CAP_USD=5
MISSION_TIMEOUT_MINUTES=45
# Optional: repo used when a coding request doesn't name one.
DEFAULT_REPO=
# Optional sandbox image override (daemon default: ghcr.io/sinameraji/hotcell-base)
SANDBOX_IMAGE=

# ── Host-side tooling ──────────────────────────────────────────────────────
# Path to the GitHub CLI used to push branches and open PRs (must be
# authenticated on the host: `gh auth login`). Keys never enter sandboxes.
GH_PATH=gh

# ── Janitor ────────────────────────────────────────────────────────────────
JANITOR_MAX_ARTIFACT_MB=100
JANITOR_ARTIFACT_MAX_AGE_DAYS=30
